{
  "name": "@hanamikoji/p2p",
  "version": "1.0.0",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm -C ../shared build && pnpm -C ../engine build && node ./scripts/build-dual.mjs",
    "build:local": "node ./scripts/build-dual.mjs",
    "test": "pnpm run build && node --test test/**/*.test.js",
    "test:local": "node --test test/**/*.test.js"
  },
  "dependencies": {
    "@hanamikoji/shared": "workspace:^",
    "@hanamikoji/engine": "workspace:^",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.3.2"
  },
  "type": "module",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./protocol": {
      "import": "./dist/protocol.js",
      "require": "./dist/protocol.cjs",
      "types": "./dist/protocol.d.ts"
    },
    "./memory": {
      "import": "./dist/transport/MemoryTransport.js",
      "require": "./dist/transport/MemoryTransport.cjs",
      "types": "./dist/transport/MemoryTransport.d.ts"
    },
    "./webrtc": {
      "import": "./dist/transport/WebRTCDataChannelTransport.js",
      "require": "./dist/transport/WebRTCDataChannelTransport.cjs",
      "types": "./dist/transport/WebRTCDataChannelTransport.d.ts"
    },
    "./transport": {
      "import": "./dist/transport/types.js",
      "require": "./dist/transport/types.cjs",
      "types": "./dist/transport/types.d.ts"
    },
    "./signalCodec": {
      "import": "./dist/signalCodec.js",
      "require": "./dist/signalCodec.cjs",
      "types": "./dist/signalCodec.d.ts"
    },
    "./inviteCodec": {
      "import": "./dist/inviteCodec.js",
      "require": "./dist/inviteCodec.cjs",
      "types": "./dist/inviteCodec.d.ts"
    }
  }
}
