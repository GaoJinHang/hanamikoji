{
  "name": "@hanamikoji/engine",
  "version": "1.0.0",
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "pnpm -C ../shared build && node ./scripts/build-dual.mjs",
    "test": "pnpm run build && node --test test/**/*.test.js",
    "test:fast": "pnpm run build && SIM_COUNT=20 node --test test/reducer.test.js test/reducerValidation.test.js test/replay.test.js test/simulation.test.js",
    "test:sim": "pnpm run build && node --test test/simulation.test.js"
  },
  "dependencies": {
    "@hanamikoji/shared": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.2"
  },
  "type": "module",
  "module": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  }
}
