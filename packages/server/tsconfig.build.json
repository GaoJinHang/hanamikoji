{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "CommonJS",
    "baseUrl": ".",
    "paths": {
      "@hanamikoji/shared": ["../shared/src/index.ts"],
      "@hanamikoji/shared/*": ["../shared/src/*"],
      "@hanamikoji/engine": ["../engine/src/index.ts"],
      "@hanamikoji/engine/*": ["../engine/src/*"]
    }
  },
  "references": [
    {
      "path": "../shared/tsconfig.build.json"
    },
    {
      "path": "../engine/tsconfig.build.json"
    }
  ],
  "include": [
    "src/**/*"
  ]
}
