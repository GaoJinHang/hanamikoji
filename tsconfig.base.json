{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "baseUrl": ".",
    "paths": {
      "@hanamikoji/shared": [
        "packages/shared/src/index.ts"
      ],
      "@hanamikoji/shared/*": [
        "packages/shared/src/*"
      ],
      "@hanamikoji/engine": [
        "packages/engine/src/index.ts"
      ],
      "@hanamikoji/engine/*": [
        "packages/engine/src/*"
      ],
      "@hanamikoji/p2p": [
        "packages/p2p/src/index.ts"
      ],
      "@hanamikoji/p2p/*": [
        "packages/p2p/src/*"
      ]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true
  }
}
