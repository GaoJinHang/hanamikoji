# Cloudflare Pages / Vite 前端环境变量
# 生产环境请改成你的后端 HTTPS 域名，例如：https://api.example.com
VITE_SOCKET_URL=https://api.example.com
VITE_API_BASE_URL=https://api.example.com

# 可选：离线 P2P ICE servers。
# 默认留空，优先支持同一 Wi-Fi / 手机热点；这通常不需要公网 STUN/TURN。
# relay signaling 只交换 offer/answer，不等于公网穿透；跨运营商网络或复杂 NAT 可能需要 STUN/TURN。
# 支持 JSON：[{"urls":"stun:stun.example.com:3478"},{"urls":"turn:turn.example.com:3478","username":"user","credential":"pass"}]
# 或逗号分隔（适合只配置 STUN）：stun:stun1.example.com:3478,stun:stun2.example.com:3478
# 不要把第三方 TURN 凭据硬编码到源码；请用部署平台的环境变量配置。
VITE_P2P_ICE_SERVERS=
