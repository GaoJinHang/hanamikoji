{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@shared/*": [
        "../shared/src/*"
      ],
      "@hanamikoji/shared": [
        "../shared/src/index.ts"
      ],
      "@hanamikoji/shared/*": [
        "../shared/src/*"
      ],
      "@hanamikoji/p2p": [
        "../p2p/src/index.ts"
      ],
      "@hanamikoji/p2p/*": [
        "../p2p/src/*"
      ],
      "@hanamikoji/engine": [
        "../engine/src/index.ts"
      ],
      "@hanamikoji/engine/*": [
        "../engine/src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    "vite.config.ts",
    "../shared/src/**/*",
    "../p2p/src/**/*",
    "../engine/src/**/*"
  ],
  "exclude": [
    "node_modules"
  ]
}
